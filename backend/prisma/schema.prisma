// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TravelMethodType {
  PERSONAL 
  COMPANY 
  AIRPLANE
}

enum RoleType {
  ADMIN
  MANAGER
  WORKER
  AGENT
}

enum DocumentType {
  MISSION_ORDER
  ABSENCE_AUTH
  EXIT_SLIP
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

enum StatusLeave {
  OUT 
  RETURNED
  NOT_RETURNED
}

model Employee {
  id               Int        @id @default(autoincrement()) 
  name             String
  username         String     @unique
  email            String     @unique
  password         String

  roles             EmployeeRole[]

  structureId      Int
  structure        Structure  @relation(fields: [structureId], references: [id])

  issuedDocuments  Document[] @relation("IssuedDocuments")
  decidedDocuments Document[] @relation("DecidedDocuments")

  refreshToken     String?
  passwordResets   PasswordReset[]
}

model Role {
  id          Int       @id @default(autoincrement())
  name        String
  type        RoleType  
  permissions String

  employees   EmployeeRole[]
}

model EmployeeRole {
  employeeId Int
  roleId     Int
  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([employeeId, roleId])
  @@index([employeeId])
  @@index([roleId])
}

model PasswordReset {
  id          Int         @id @default(autoincrement())

  token       String    
  expiresAt   DateTime

  employeeId  Int
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now()) 

  @@index([employeeId])
}

model Structure {
  id        Int         @id @default(autoincrement())
  name      String

  parentId  Int?
  parent    Structure?  @relation("StructureHierarchy", fields: [parentId], references: [id])
  children  Structure[] @relation("StructureHierarchy")

  employees Employee[]
}


model LeaveSession {
  id          Int       @id @default(autoincrement())
  employeeId  Int          
  status      StatusLeave?
  leaveTime   DateTime?
  returnTime  DateTime?
  createdAt   DateTime  @default(now())

  documentId  Int       @unique
  document    Document  @relation(fields: [documentId], references: [id] , onDelete: Cascade)

}

model Document {
  id               Int          @id @default(autoincrement())
  status           Status       @default(PENDING)
  createdAt        DateTime     @default(now())
  qrCode           String?      @unique
  authIssuedAt     DateTime?
  type             DocumentType

  managerComment   String?

  issuedById       Int
  employee         Employee     @relation("IssuedDocuments", fields: [issuedById], references: [id])

  decisionMadeById Int?
  decisionMadeBy   Employee?    @relation("DecidedDocuments", fields: [decisionMadeById], references: [id])

  missionOrder     MissionOrder?
  absenceAuth      AbsenceAuth?
  exitSlip         ExitSlip?

  leaveSession     LeaveSession?
}

model MissionOrder {
  id               Int       @id @default(autoincrement())
  destination      String
  duration         Int
  purpose          String
  travelMethod  TravelMethodType @default(PERSONAL)

  documentId  Int       @unique
  document    Document  @relation(fields: [documentId], references: [id] , onDelete: Cascade)
}

model AbsenceAuth {
  id          Int       @id @default(autoincrement())
  startDate   DateTime
  endDate     DateTime
  reason      String

  documentId  Int       @unique
  document    Document  @relation(fields: [documentId], references: [id] , onDelete: Cascade)
}

model ExitSlip {
  id          Int       @id @default(autoincrement())
  exitTime    DateTime
  returnTime  DateTime
  gate        String

  documentId  Int       @unique
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
}