// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  Id              Int    @id @default(autoincrement())
  Name            String
  Username        String @unique
  Password        String

  Role            Role @relation(fields: [RoleId] , references: [Id]) 
  RoleId          Int
  
  Documents       Document[]

  Structure       Structure @relation(fields: [StructureId] , references: [Id])
  StructureId     Int
}

model Structure {
  Id              Int @id @default(autoincrement())
  Name            String 

  Children        Structure[] @relation(name: "ChildrenParent") 
  // - this relation represents one to many on self

  // - Children field is the oppsite side in this one to many relation 
  //Note : structure has a lot of children and have one parent or none

  Parent          Structure? @relation(name: "ChildrenParent", fields: [ParentId] , references: [Id])
  ParentId        Int?  // parent with ? to express that the parent might be null
  // the children have unique parent it has to be at application level 


          

  Employees       Employee[]
}

model Role {
  Id              Int @id @default(autoincrement())
  Name            String 
  Permissions     String 
  Employees       Employee[]
}

model Document {
  Id              Int @id @default(autoincrement())
  Status          String 
  CreatedAT       DateTime @default(now())
  QrCode          String
  AuthIssuedAt    DateTime?

  MissionOrder     MissionOrder?
  AbsenceAuth      AbsenceAuth?
  ExitSlip         ExitSlip?

  Employee         Employee @relation(fields: [EmployeeId] , references: [Id])
  EmployeeId       Int

}

model MissionOrder {
  Id              Int @id @default(autoincrement())
  Destination     String
  Duration        Int
  Purpose         String
  
  Document        Document @relation(fields: [DocumentId] , references: [Id])
  DocumentId      Int @unique
}


model AbsenceAuth {
  Id              Int @id @default(autoincrement())
  StartDate       DateTime
  EndDate         DateTime
  Reason          String

  Document        Document @relation(fields: [DocumentId] , references: [Id])
  DocumentId      Int @unique
}

model ExitSlip {
  Id              Int @id @default(autoincrement())
  ExitTime        DateTime
  ReturnTime      DateTime
  Gate            String

  Document        Document @relation(fields: [DocumentId] , references: [Id])
  DocumentId      Int @unique
}
